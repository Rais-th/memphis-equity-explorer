{
  "crons": [
    { "path": "/api/cron/refresh", "schedule": "0 8 * * *" }
  ],
  "headers": [
    {
      "source": "/data/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=600, s-maxage=600" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
